% ============================================================
%  BOTTOM-RIGHT FOLDED CORNER
%  Two overlapping curved fills that create a page-curl / 
%  dog-ear effect — matches the crimson accent in the image.
%
%  Usage inside overlay={...}:  \foldedcorner{DefiPill}{frame}
% ============================================================
\newcommand{\foldedcorner}[2]{%
  % Outer (larger, darker) curved shape
  \fill[#1!90, opacity=0.80]
    ([xshift= -36pt]#2.south east)
    .. controls
       ([xshift=-10pt, yshift=  6pt]#2.south east) and
       ([xshift=  0pt, yshift= 22pt]#2.south east) ..
    (#2.south east) -- cycle;
  % Inner (smaller, lighter) curved shape — creates depth
  \fill[#1!65, opacity=0.70]
    ([xshift= -20pt]#2.south east)
    .. controls
       ([xshift= -5pt, yshift=  4pt]#2.south east) and
       ([xshift=  0pt, yshift= 13pt]#2.south east) ..
    (#2.south east) -- cycle;
}

% ============================================================
%  1. DEFINITION BOX  (定义)
%     Pill uses `attach boxed title to top left` so it straddles
%     the top border naturally. Bottom-right gets the fold accent.
% ============================================================
\newtcolorbox[
  auto counter,
  number within = section,
]{definition}[2][]{%
  enhanced,
  breakable,
  arc      = 6pt,
  boxrule  = 0.6pt,
  colframe = DefiFrame,
  colback  = DefiBack,
  left     = 10pt,
  right    = 10pt,
  top      = 8pt,
  bottom   = 10pt,
  % soft drop shadow
  drop fuzzy shadow = {0.5pt}{-1.5pt}{0pt}{0.3pt}{black!20},
  % ── Pill title straddles top border ─────────────────────
  title = {%
    \textbf{定义~\thetcbcounter.}%
    \ifstrempty{#2}{}{\enspace\textit{#2}}%
  },
  attach boxed title to top left = {
    xshift = 10pt,
    yshift = -\tcboxedtitleheight/2,
  },
  boxed title style = {
    enhanced,
    colback  = DefiPill,
    colframe = DefiPill,
    arc      = 4pt,
    boxrule  = 0pt,
    left     = 6pt,
    right    = 6pt,
    top      = 2.5pt,
    bottom   = 2.5pt,
    sharp corners = south,  % flat bottom, rounded top
    fontupper = \bfseries\small\color{white}\sffamily,
  },
  % ── Folded corner overlay ───────────────────────────────
  overlay unbroken = {\foldedcorner{DefiPill}{frame}},
  overlay last     = {\foldedcorner{DefiPill}{frame}},
  #1
}

