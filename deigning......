% ============================================================
%  FOLDED RIBBON CORNER macro
%  Replicates the bottom-right folded corner in the image.
%  Usage inside overlay={}:
%    \ribboncorner{frame}{defirose}
%
%  The shape: a dark-rose filled quadrilateral that looks like
%  a page corner fold — flat at the bottom, angled diagonal cut.
% ============================================================
\newcommand{\ribboncorner}[2]{%
  % Outer dark fold — larger triangle/quadrilateral
  \fill[#2!85, opacity=0.85]
    ([xshift=-28mm]#1.south east) --
    (#1.south east) --
    ([yshift= 18mm]#1.south east) --
    ([xshift=-10mm, yshift=10mm]#1.south east) -- cycle;
  % Inner lighter layer — narrower, creates depth
  \fill[#2!60, opacity=0.70]
    ([xshift=-16mm]#1.south east) --
    (#1.south east) --
    ([yshift= 10mm]#1.south east) --
    ([xshift=-6mm, yshift=6mm]#1.south east) -- cycle;
  % Tiny highlight triangle at the fold tip
  \fill[white, opacity=0.25]
    ([xshift=-10mm, yshift=10mm]#1.south east) --
    ([xshift=-16mm]#1.south east) --
    ([xshift=-6mm,  yshift= 6mm]#1.south east) -- cycle;
}

% ============================================================
%  1. DEFINITION BOX  (定义)
%
%  From the image:
%  • Pale lavender background (#EDE8EF), NO left border rule
%  • Thin outer frame (subtle)
%  • Title = small crimson rounded-rect pill, positioned inside
%    the box at the top-left (not floating above the border)
%  • Title text: bold "定义 X.X.X." + italic name, white on crimson
%  • Bottom-right: crimson folded ribbon corner (two-tone fold)
% ============================================================
\newtcolorbox[
  auto counter,
  number within = section,
]{definition}[2][]{%
  enhanced,
  breakable,
  arc       = 3pt,
  boxrule   = 0.4pt,
  colframe  = defirose!25,
  colback   = defiback,
  left      = 1em,
  right     = 1em,
  top       = 2.2em,       % make room for pill inside the box
  bottom    = 1em,
  % ── Ribbon corner overlay ─────────────────────────────
  overlay unbroken = {%
    \ribboncorner{frame}{defirose}
    % ── Pill title drawn inside box ──────────────────
    \node[
      fill        = defirose,
      text        = white,
      font        = \bfseries\sffamily\small,
      inner xsep  = 7pt,
      inner ysep  = 3pt,
      rounded corners = 3pt,
      anchor      = west,
    ] at ([xshift=1em, yshift=-1.35em]frame.north west)
      {定义~\thetcbcounter.\enspace\textit{#2}};
  },
  overlay first = {%
    % ── Pill title for breakable first part ──────────
    \node[
      fill        = defirose,
      text        = white,
      font        = \bfseries\sffamily\small,
      inner xsep  = 7pt,
      inner ysep  = 3pt,
      rounded corners = 3pt,
      anchor      = west,
    ] at ([xshift=1em, yshift=-1.35em]frame.north west)
      {定义~\thetcbcounter.\enspace\textit{#2}};
  },
  overlay last = {%
    \ribboncorner{frame}{defirose}
  },
  #1
}

