\subsubsection*{Some notations}

% Definition
\begin{definition}{transgressive}
  An element $\alpha \in H^{p,q}_{\bar\partial}(F)$ is called
  \textit{transgressive} if there is a representative
  $\alpha \in \mathcal{A}^{p,q}_{\bar\partial}(F)$ which extends to a form
  $\widetilde\alpha \in \mathcal{A}^{p,q}_{\bar\partial}(F)$ such that
  $\widetilde\alpha = \pi^*\beta$ for some $\bar\partial$-closed form
  $\beta \in \mathcal{A}^{p,q+1}_{\bar\partial}(B)$.
\end{definition}

\medskip

The following are all the settings in this paper.

\begin{enumerate}
  \item $i^*\colon \mathcal{A}^{p,q}(M)\to\mathcal{A}^{p,q}(N)$ is surjective,
        which induces a short exact sequence for the pair $(M,N)$ of complexes
        \[
          0\to\mathcal{A}^{p,\bullet}(M,N)\to\mathcal{A}^{p,\bullet}(M)
          \xrightarrow{\,i^*\,}\mathcal{A}^{p,\bullet}(N)\to 0
        \]
        and a long exact sequence
        \[
          \cdots\to H^{p,\bullet}_{\bar\partial}(M,N)\to
          H^{p,\bullet}_{\bar\partial}(M)\to
          H^{p,\bullet}_{\bar\partial}(N)\to\cdots
        \]

  \item \ldots
\end{enumerate}

\subsecbadge{1.1.2}{Blow-up with the center at a point}

\medskip

\begin{definition}{Blow-up}
  Let $X$ be a complex manifold and let $Y\subset X$ be a closed submanifold.
  The \textit{Blow-up of $X$ along $Y$} is a complex manifold
  $\widehat{X}:=\mathrm{Bl}_Y(X)$ together with a proper holomorphic map
  $\sigma\colon\widehat{X}\to X$.
\end{definition}

\medskip

\begin{examplebox}{Blow-up with the center at a point}
  Consider the situation of the line bundle $\mathcal{O}(-1)$ over the
  projective manifold $\mathbb{P}^n$, which is given as the tautological
  bundle whose fiber over $[v]\in\mathbb{P}^n$ is the line
  $\mathbb{C}\,v\subset\mathbb{C}^{n+1}$.
\end{examplebox}

