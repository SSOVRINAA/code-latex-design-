\newcommand\bb@subsecformat[1]{%
  \gdef\bb@subsectitle{#1}\bb@drawsubsec}
\newcommand\bb@drawsubsec{%
  \vspace{1ex}\noindent
  \makebox[0pt][l]{\def\rad{5pt}\def\inrad{3pt}%
    \begin{tikzpicture}[remember picture]
      \path[fill=outermarginfgcolor,
            drop shadow={opacity=0.3,
                         shadow xshift=0.5mm,shadow yshift=-0.5mm}]
        node[append after command={
          ([shift={(\rad,\rad)}]sec.north west)
            arc[start angle=90,end angle=180,radius=\rad]
          {[rounded corners=\inrad]--(sec.south west)}
          --([yshift=-3mm]$(sec.south west)!0.5!(sec.south east)$)
          {[rounded corners=\inrad]--(sec.south east)}
          --(sec.north east)
            arc[start angle=180,end angle=90,radius=\rad]--cycle},
          text=white,font=\sffamily\bfseries,
          align=center,inner ysep=1.5mm,inner xsep=1mm]
        (sec) at (0,0) {\thesubsection};
      \begin{pgfonlayer}{bottom}
        \fill[outermarginfgcolor!60!black,opacity=0.8]
          ([xshift=\rad,yshift=\rad]sec.north east)
            to[out=0,in=-81,looseness=1.5]
            ([xshift=1.8*\rad]sec.north east) --
          (sec.north east) |- cycle;
      \end{pgfonlayer}
      \node[text=black,font=\large\bfseries,below right]
        at ([shift={(2mm,6.5mm)}]sec.south east)
        {\begin{varwidth}{.88\linewidth}%
           \setlength\baselineskip{18pt}\bb@subsectitle%
         \end{varwidth}};
      \begin{pgfonlayer}{bottom}
        \draw[gray,dashed,opacity=0.5]
          (sec.north west) -- ([xshift=4*\rad]sec.north east);
      \end{pgfonlayer}
    \end{tikzpicture}}\par\vspace{3.5ex}}

\titleformat{\subsection}{}{}{0pt}{\bb@subsecformat}

