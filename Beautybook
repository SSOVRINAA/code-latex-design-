\makeatletter
\newcommand\chapimage[1]{\gdef\@chapimage{#1}}
\gdef\@chapimage{}

%% The wrapper called by \titleformat — saves title, then draws
\newcommand\bb@chapterformat[1]{%
  \gdef\bb@thetitle{#1}%
  \bb@drawchapter
}

\newcommand\bb@drawchapter{%
  \makebox[0pt][l]{\def\rad{7pt}%
    \begin{tikzpicture}[remember picture,overlay]
      %% ── gradient shade across top ~20% of page ──────────
      \begin{pgfonlayer}{bottom}
        \ifodd\value{page}
          \shade[right color=outermarginbgcolor!30,
                 middle color=outermarginbgcolor!50,
                 left  color=outermarginfgcolor!30]
            (current page.north west)
            rectangle ++(\paperwidth,-.2\paperheight+0.3cm);
        \else
          \shade[left  color=outermarginbgcolor!30,
                 middle color=outermarginbgcolor!50,
                 right color=outermarginfgcolor!30]
            (current page.north west)
            rectangle ++(\paperwidth,-.2\paperheight+0.3cm);
        \fi
        %% thin teal rule at 4.45 cm from top
        \fill[outermarginfgcolor,opacity=.5]
          ([shift={(0,-4.45cm)}]current page.north west)
          rectangle ++(\paperwidth,-2mm);
      \end{pgfonlayer}
      %% ── "Part I" wavy banner centred on the rule ────────
      \path[fill=outermarginfgcolor]
        node[append after command={
          ([xshift=-3*\rad]chapinfoofpart.north west)
            to[out=0,in=-180,looseness=1]
            ([xshift=\rad]chapinfoofpart.south west) --
          ([xshift=-\rad]chapinfoofpart.south east)
            to[out=0,in=180,looseness=1]
            ([xshift=3*\rad]chapinfoofpart.north east) --cycle},
          text=white,font=\sffamily\large\bfseries,
          align=center,minimum height=1cm]
        (chapinfoofpart)
        at ([shift={(0,-4.95cm)}]current page.north)
        {Part\ \thepart};
      %% shadow tails behind each curl end
      \begin{pgfonlayer}{bottom}
        \fill[outermarginfgcolor!90,opacity=0.5]
          ([shift={(-3*\rad,0)}]chapinfoofpart.north west)
            to[out=180,in=0,looseness=1] +(-4*\rad,-1.2cm) --
          ([shift={(7*\rad,-1.2cm)}]chapinfoofpart.north east)
            to[out=-180,in=0,looseness=1] +(-4*\rad,1.2cm);
      \end{pgfonlayer}
      %% ── chapter number badge (odd = left side) ───────────
      \ifodd\value{page}
        \begin{pgfonlayer}{top}
          %% tall teal rectangle extending 2 cm above page top
          \fill[outermarginfgcolor,opacity=0.7,rounded corners=5pt]
            node[append after command={
              ([yshift=2cm]chapnum.north west)
              rectangle (chapnum.south east)},
              right,text=white,minimum width=2cm,
              align=center,font=\sffamily\bfseries]
            (chapnum)
            at ([shift={(1.5cm,-2.5cm)}]current page.north west)
            {\scalebox{3}{\thechapter}};
          %% six-pointed star pattern overlay
          \begin{pgfonlayer}{foreground}
            \pattern[pattern=sixpointed stars,
                     pattern color=white,opacity=0.6,
                     rounded corners=5pt]
              ([yshift=2cm]chapnum.north west)
              rectangle (chapnum.south east);
          \end{pgfonlayer}
          %% upward fade on the badge
          \fill[outermarginfgcolor,path fading=fade up,
                rounded corners=5pt]
            ([yshift=2cm]chapnum.north west)
            rectangle (chapnum.south east);
          %% chapter title — top-right in small caps
          \node[above left,
                font=\sc\fontsize{22pt}{22pt}\selectfont,
                align=center]
            at ([shift={(0cm,-4.45cm)}]current page.north east)
            {\begin{varwidth}{.7\linewidth}%
               \baselineskip=2ex\bb@thetitle%
             \end{varwidth}};
        \end{pgfonlayer}
        %% chapter image behind badge (bottom layer)
        \begin{pgfonlayer}{bottom}
          \ifdefempty{\@chapimage}{}{%
            \node[right]
              at ([shift={(-0.5cm,-2.8cm)}]current page.north west)
              {\includegraphics[width=7cm]{\@chapimage}};}
        \end{pgfonlayer}
      \else
        %% ── even page: mirror layout ─────────────────────
        \begin{pgfonlayer}{top}
          \fill[outermarginfgcolor,opacity=0.7,rounded corners=5pt]
            node[append after command={
              ([yshift=2cm]chapnum.north west)
              rectangle (chapnum.south east)},
              left,text=white,minimum width=2cm,
              align=center,font=\sffamily\bfseries]
            (chapnum)
            at ([shift={(-1.5cm,-2.5cm)}]current page.north east)
            {\scalebox{3}{\thechapter}};
          \begin{pgfonlayer}{foreground}
            \pattern[pattern=sixpointed stars,
                     pattern color=white,opacity=0.6,
                     rounded corners=5pt]
              ([yshift=2cm]chapnum.north west)
              rectangle (chapnum.south east);
          \end{pgfonlayer}
          \fill[outermarginfgcolor,path fading=fade up,
                rounded corners=5pt]
            ([yshift=2cm]chapnum.north west)
            rectangle (chapnum.south east);
          \node[above right,
                font=\sc\fontsize{22pt}{22pt}\selectfont,
                align=center]
            at ([shift={(0cm,-4.45cm)}]current page.north west)
            {\begin{varwidth}{.7\linewidth}%
               \baselineskip=2ex\bb@thetitle%
             \end{varwidth}};
        \end{pgfonlayer}
        \begin{pgfonlayer}{background}
          \ifdefempty{\@chapimage}{}{%
            \node[left]
              at ([shift={(0.5cm,-2.8cm)}]current page.north east)
              {\includegraphics[width=7cm]{\@chapimage}};}
        \end{pgfonlayer}
      \fi
      %% ── wavy page-number badge at bottom centre ─────────
      \path[fill=outermarginbgcolor]
        node[append after command={
          ([xshift=-2*\rad]pagenumber.south west)
            to[out=0,in=180,looseness=1]
            ([xshift=\rad]pagenumber.north west) --
          ([xshift=-\rad]pagenumber.north east)
            to[out=0,in=-180,looseness=1]
            ([xshift=2*\rad]pagenumber.south east) --cycle},
          text=outermarginfgcolor,
          font=\sffamily\fontsize{15}{15}\selectfont\bfseries,
          align=center,minimum height=0.4cm,
          minimum width=1.3cm,inner sep=1.5mm]
        (pagenumber)
        at ([shift={(0,0.3cm)}]current page.south)
        {\thepage};
    \end{tikzpicture}}%
}

