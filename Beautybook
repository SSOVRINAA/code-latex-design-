\chapter{Blow-up}

\section{Basic Concepts and Examples}
\subsection{Example I}
\subsubsection*{Some notations}

\begin{definition}[transgressive]
  An element $\alpha \in H^{p,q}_{\bar\partial}(F)$ is called
  \textit{transgressive} if there is a representative
  $\alpha \in \mathcal{A}^{p,q}_{\bar\partial}(F)$ which extends to
  $\widetilde\alpha$ such that $\widetilde\alpha=\pi^*\beta$ for
  some $\bar\partial$-closed $\beta\in\mathcal{A}^{p,q+1}_{\bar\partial}(B)$.
\end{definition}

The following are all the settings in this paper.
\begin{enumerate}
  \item $i^*\colon\mathcal{A}^{p,q}(M)\to\mathcal{A}^{p,q}(N)$
        is surjective, which induces a short exact sequence
        \[0\to\mathcal{A}^{p,\bullet}(M,N)\to\mathcal{A}^{p,\bullet}(M)
        \xrightarrow{i^*}\mathcal{A}^{p,\bullet}(N)\to 0\]
        and a long exact sequence
        \[\cdots\to H^{p,\bullet}_{\bar\partial}(M,N)\to
        H^{p,\bullet}_{\bar\partial}(M)\to H^{p,\bullet}_{\bar\partial}(N)
        \to\cdots\]
  \item \ldots
\end{enumerate}

\subsection{Blow-up with the center at a point}

\begin{definition}[Blow-up]
  Let $X$ be a complex manifold and $Y\subset X$ closed. The
  \textit{Blow-up} $\widehat{X}:=\mathrm{Bl}_Y(X)$ comes with a
  proper holomorphic map $\sigma\colon\widehat{X}\to X$.
\end{definition}

\begin{example}[Blow-up with the center at a point]
  Consider $\mathcal{O}(-1)$ over $\mathbb{P}^n$, the tautological bundle
  whose fiber over $[v]\in\mathbb{P}^n$ is
  $\mathbb{C}\,v\subset\mathbb{C}^{n+1}$.
\end{example}

\begin{theorem}[Main result]
  Every compact complex manifold admits a blow-up along any closed
  submanifold, and the result is again compact.
\end{theorem}

