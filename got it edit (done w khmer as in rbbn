\secbadge{ផ្នែក ១.១}{និយមន័យ និង លំហាត់គំរូ}

\begin{definition}[តួអក្សរ]
  នេះគឺជាអត្ថបទដែលប្រើប្រាស់ហ្វុង \textbf{Khmer OS Siemreap}។ ចំណែកឯចំណងជើងនៅក្នុងបូ \en{ribbon} ខាងលើគឺប្រើប្រាស់ហ្វុង \textbf{Khmer OS Muol Light} ដោយរក្សារូបរាងដើមទាំងស្រុង។
\end{definition}

\begin{example}[ការគណនា]
  ឧបមាថា $x + y = 10$។ គណនាតម្លៃនៃ $z$ បើ $z = x^2$។
\end{example}

\begin{theorem}[មេគុណ]
  គ្រប់ចំនួនពិត $n$ តែងតែមានលក្ខណៈដូចខាងក្រោម៖
  \[ \sum_{i=1}^{n} i = \frac{n(n+1)}{2} \]
\end{theorem}

