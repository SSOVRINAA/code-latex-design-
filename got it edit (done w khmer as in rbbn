\newcounter{thm}[section]\renewcommand{\thethm}{\thesection.\arabic{thm}}
\newenvironment{theorem}[1][]{%
  \refstepcounter{thm}\def\tcbtitletext{#1}%
  \begin{tcolorbox}[beautylemma={DaiLv}{ទ្រឹស្តីបទ~\thethm}]}{\end{tcolorbox}}

\newcounter{lem}[section]\renewcommand{\thelem}{\thesection.\arabic{lem}}
\newenvironment{lemma}[1][]{%
  \refstepcounter{lem}\def\tcbtitletext{#1}%
  \begin{tcolorbox}[beautylemma={DianLan}{សេចក្តីសម្រាយ~\thelem}]}{\end{tcolorbox}}

