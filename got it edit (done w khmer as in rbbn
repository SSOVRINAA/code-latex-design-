% --- 4. BeautyBook Ribbon Macros (Updated for Khmer Muol) ---
\makeatletter
\newcommand{\bbLemmaUnbroken}[2]{%
   \def\Rad{3.5pt}\def\theight{0.57cm}\def\rad{7pt}%
   \path[fill=#2,drop shadow={opacity=0.3,shadow xshift=.05cm,shadow yshift=-.05cm}]%
     node[append after command={%
       ([xshift=-1.5*\rad]thmname.north west) to[out=0,in=180,looseness=1]%
       ([xshift=2.5*\rad]thmname.south west) --%
       ([xshift=-\rad]thmname.south east) to[out=0,in=180,looseness=1]%
       ([xshift=3*\rad]thmname.north east) --cycle},%
       text=white,
       font=\khmerheadingfont, % <--- FONT UPDATED TO MUOL LIGHT
       align=center,inner ysep=1.5mm,%
       minimum height=0.6cm,right] (thmname)%
     at ([xshift=\rad,yshift=-.7*\rad]frame.north west)%
     {\hspace*{10pt}#1.\ \ifdefvoid{\tcbtitletext}{}{(\itshape\tcbtitletext)}};%
   \begin{pgfonlayer}{bottom}%
     \fill[#2,opacity=0.5]([xshift=-1.5*\rad]thmname.north west) to[out=180,in=305,looseness=1.5] +(3pt,-6pt) -| ++(12pt,0)--cycle;%
     \fill[#2,opacity=0.5]([xshift=3*\rad]thmname.north east) to[out=0,in=-90] +(5pt,-5pt) -| ++(-10pt,0) --cycle;%
   \end{pgfonlayer}%
   \def\tlen{1.5cm}%
   \path[fill=#2,drop shadow={opacity=0.3,shadow xshift=.3pt}]%
     ([xshift=-2*\rad,yshift=-5pt]frame.south east) coordinate (SE)%
     to[out=0,in=180] +(4*\rad,5pt+\theight) --([shift={(-\tlen+4*\rad,5pt+\theight)}]SE) to[out=180,in=0] +(-4*\rad,-5pt-\theight) --cycle;%
}

\newcommand{\bbLemmaFirst}[2]{%
   \def\Rad{3.5pt}\def\theight{0.57cm}\def\rad{7pt}%
   \path[fill=#2,drop shadow={opacity=0.3,shadow xshift=.05cm,shadow yshift=-.05cm}]%
     node[append after command={%
       ([xshift=-1.5*\rad]thmname.north west) to[out=0,in=180,looseness=1]%
       ([xshift=2.5*\rad]thmname.south west) --%
       ([xshift=-\rad]thmname.south east) to[out=0,in=180,looseness=1]%
       ([xshift=3*\rad]thmname.north east) --cycle},%
       text=white,
       font=\khmerheadingfont, % <--- FONT UPDATED TO MUOL LIGHT
       align=center,inner ysep=1.5mm,%
       minimum height=0.6cm,right] (thmname)%
     at ([xshift=\rad,yshift=-.7*\rad]frame.north west)%
     {\hspace*{10pt}#1.\ \ifdefvoid{\tcbtitletext}{}{(\itshape\tcbtitletext)}};%
}

\newcommand{\bbLemmaLast}[1]{%
   \def\Rad{3.5pt}\def\rad{7pt}\def\theight{0.57cm}\def\tlen{1.5cm}%
   \path[fill=#1,drop shadow={opacity=0.3,shadow xshift=.3pt}]%
     ([xshift=-2*\rad,yshift=-5pt]frame.south east) coordinate (SE)%
     to[out=0,in=180] +(4*\rad,5pt+\theight) --([shift={(-\tlen+4*\rad,5pt+\theight)}]SE) to[out=180,in=0] +(-4*\rad,-5pt-\theight) --cycle;%
}
\makeatother

% --- 5. TColorBox Style Logic ---
\tcbset{
  beautylemma/.style 2 args={
    enhanced,breakable,arc=3pt,boxrule=0pt,opacityframe=0,opacityback=0.98,
    interior style={top color=#1!9,middle color=#1!6,bottom color=#1!3},
    fuzzy shadow={-0.6mm}{0.6mm}{0mm}{0.3mm}{white!50!gray},
    top=6mm,bottom=5mm,left=4mm,right=4mm,
    before skip=18pt,after skip=18pt,
    overlay unbroken=\bbLemmaUnbroken{#2}{#1},
    overlay first  =\bbLemmaFirst{#2}{#1},
    overlay last   =\bbLemmaLast{#1},
  }
}

% --- 6. Environments ---
\newcounter{defi}[section]\renewcommand{\thedefi}{\thesection.\arabic{defi}}
\newenvironment{definition}[1][]{%
